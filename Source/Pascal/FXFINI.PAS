IMPLEMENTATION

CONST SYSTEM_INI_NAME = 'FORMIX.INI';

TYPE PTextBuffer = ^TTextBuffer;
     TTextBuffer = ARRAY[0..4095] OF CHAR;
VAR
    IniFileBuffer : PTextBuffer;


TYPE PIniLineCache = ^TIniLineCache;
     TIniLineCache = PACKED RECORD
      IniVar  : STRING[30];
      IniLine : STRING[100];
      Next    : PIniLineCache;
     END;

     PIniSectionCache = ^TIniSectionCache;
     TIniSectionCache = PACKED RECORD
      LinesInSection : PIniLineCache;
      IniSection     : INISection;
      Next           : PIniSectionCache;
     END;

VAR IniFileCache    : PIniSectionCache;
    SysIniFileCache : PINiSectionCache;


FUNCTION SplitString(WrkString : STRING;VAR Identifier,ExtVar : STRING) : INTEGER;
VAR EqPos : INTEGER;
BEGIN
 EqPos := Pos('=',WrkString);
 IF EqPos > 1 THEN
  BEGIN
   Identifier := COPY(WrkString,1,Eqpos-1);
   ExtVar     := COPY(WrkString,EqPos+1,Length(WrkString));
  END;
 SplitString := EqPos;
END;

FUNCTION GetSectionName (Section : INISection) : STRING;
BEGIN
 CASE Section OF
  main    : GetSectionName := 'MAIN';
  printer : GetSectionName := 'PRINTER';
  ubi     : GetSectionName := 'UBI';
  scale   : GetSectionName := 'SCALE';
  colours : GetSectionName := 'COLOURS';
  compile : GetSectionName := 'COMPILE';
  eltron  : GetSectionName := 'ELTRON';
 END;
END;

FUNCTION GetSectionFromName (SectionName : STRING) : INISection;
VAR I : INTEGER;
BEGIN
 Stripped(SectionName,Length(SectionName),' ');
 FOR I := ORD(Main) TO ORD(Eltron) DO
  BEGIN
   IF (StringIComp(SectionName,GetSectionName(INISection(I))) = 0) THEN
    BEGIN
     GetSectionFromName := INISection(I);
     EXIT;
    END;
  END;
 GetSectionFromName := Main;
END;



PROCEDURE PreCacheIniFiles;


   PROCEDURE AddLinesToCache(VAR CacheHeader : PIniSectionCache;FileName : STRING);
   CONST MaxRetry = 1000;
   VAR IniFile    : TEXT;
       IniOpenErr : INTEGER;
       ASearchrec : SearchRec;
       InSection  : BOOLEAN;
       FileTimeOut: LONGINT;

       CacheSection : PIniSectionCache;
       CacheLine    : PIniLineCache;
       WrkString    : STRING;


      FUNCTION CheckNewSection : BOOLEAN;
      VAR CheckSection: STRING;
          i           : BYTE;
      BEGIN
       CheckNewSection := FALSE;
       IF WrkString[1] = '[' THEN { SectionStart }
        BEGIN
         CheckNewSection := TRUE;
         New(CacheSection);
         CacheSection^.Next := CacheHeader;
         CacheHeader        := CacheSection;

         CacheSection^.LinesInSection := NIL;
         CacheSection^.IniSection   := GetSectionFromName(Copy(WrkString,2,Pos(']',WrkString)-2));
        END;
      END;

   BEGIN
    Assign(IniFile,FileName);
    New(IniFileBuffer);
    SetTextBuf(IniFile,IniFileBuffer^);
    FileTimeOut      := 0;
    REPEAT
     {$I-}
      Reset(IniFile);
     {$I+}
     IniOpenErr := IOResult;
     IF IniOpenErr <> 0 THEN
      BEGIN
       Inc(FileTimeOut);
       FindFirst(FileName,anyFile,ASearchRec);
       IF (DosError <> 0) OR (FileTimeOut > MaxRetry) THEN BREAK; { IF FILE NOT THERE, FORGET IT }
       IF Assigned(PROP_CommsProc) THEN PROP_CommsProc;
      END;
    UNTIL IniOpenErr = 0;
    { if opened ini file OK check each line }
    IF IniOpenErr = 0 THEN
     BEGIN
      CacheSection := NIL;
      { Find Relevant Section In INI File }
      WHILE NOT EOF(IniFile) DO
       BEGIN
        ReadLn(IniFile, WrkString);
        Stripped(WrkString,Length(WrkString),' ');
        IF (NOT CheckNewSection) THEN
         BEGIN
          IF (CacheSection <> NIL) AND (NOT NowtButSpace(WrkString)) THEN
           BEGIN
            New(CacheLine);
            CacheLine^.Next := CacheSection^.LinesInSection;
            CacheSection^.LinesInSection := CacheLine;
            SplitString(WrkString,CacheLine^.IniVar,CacheLine^.IniLine);
           END;
         END;
       END;
      Close(IniFile);
     END;
    Dispose(IniFileBuffer);
   END;

BEGIN
 AddLinesToCache(IniFileCache,FOPS6INI_VAR);
 IF (StringIComp(FOPS6INI_VAR,SYSTEM_INI_NAME) <> 0) THEN
  AddLinestoCache(SysIniFileCache,SYSTEM_INI_NAME);
END;

PROCEDURE UnCacheIniFiles;
VAR DelSection : PIniSectionCache;
    DelLine    : PIniLineCache;
BEGIN
 WHILE (IniFileCache <> NIL) DO
  BEGIN
   DelSection := IniFileCache;
   WHILE (IniFileCache^.LinesInSection <> NIL) DO
    BEGIN
     DelLine := IniFileCache^.LinesInSection;
     IniFileCache^.LinesInSection := IniFileCache^.LinesInSection^.Next;
     Dispose(DelLine);
    END;
   IniFileCache := IniFileCache^.Next;
   Dispose(DelSection);
  END;

 WHILE (SysIniFileCache <> NIL) DO
  BEGIN
   DelSection := SysIniFileCache;
   WHILE (SysIniFileCache^.LinesInSection <> NIL) DO
    BEGIN
     DelLine := SysIniFileCache^.LinesInSection;
     SysIniFileCache^.LinesInSection := SysIniFileCache^.LinesInSection^.Next;
     Dispose(DelLine);
    END;
   SysIniFileCache := SysIniFileCache^.Next;
   Dispose(DelSection);
  END;
END;

FUNCTION GetVarFromCache(VarName : INIVAR;Cache : PINISectionCache) : STRING;
VAR SectionLoop : PIniSectionCache;
    LineLoop    : PIniLineCache;
BEGIN
 GetVarFromCache := '';
 SectionLoop := Cache;
 WHILE (SectionLoop <> NIL) AND (SectionLoop^.IniSection <> VarName.S) DO
  SectionLoop := SectionLoop^.Next;
 IF (SectionLoop <> NIL) THEN
  BEGIN
   LineLoop := SectionLoop^.LinesInSection;
   WHILE (LineLoop <> NIL) DO
    BEGIN
     IF (StringIComp(VarName.V,LineLoop^.IniVar) = 0) THEN
      BEGIN
       GetVarFromCache := LineLoop^.IniLine;
       EXIT;
      END;
     LineLoop := LineLoop^.Next;
    END;
  END;
END;

FUNCTION GetExtVar(VarName : INIVAR; SearchFrom : TExternSource) : STRING;
{ returns empty string if unsuccessful }
VAR
   WrkString : STRING;
   i         : INTEGER;


    FUNCTION FoundInWrkString : BOOLEAN;
    { Loads return string for parent function }
    VAR EqPos : INTEGER;
        Identifier,ExtVar : STRING;
    BEGIN
      FoundInWrkString := FALSE;
      EqPos := SplitString(WrkString,Identifier,ExtVar);
      IF EqPos > 1 THEN
       BEGIN
        IF (StringIComp(Identifier,VarName.V) = 0) THEN
         BEGIN
          GetExtVar := ExtVar;
          FoundInWrkString := TRUE;
         END;
       END;
    END;{ FoundInWrkString }

    FUNCTION Find_IN_INI_File (FileName : STRING) : BOOLEAN;
    CONST MaxRetry = 1000;
    VAR IniFile    : TEXT;
        IniOpenErr : INTEGER;
        ASearchrec : SearchRec;
        InSection  : BOOLEAN;
        FileTimeOut: LONGINT;

      FUNCTION SectionStart : BOOLEAN;
      VAR CheckSection: STRING;
          i           : BYTE;
      BEGIN
       SectionStart := FALSE;
       IF WrkString[1] = '[' THEN { SectionStart }
        BEGIN
         IF NOT InSection THEN
          BEGIN
           { Set In Section If Section Name Equal Variable Section }
           CheckSection := Copy(WrkString,2,Pos(']',WrkString)-2);
           FOR i := 1 TO Length(CheckSection) DO
            CheckSection[i] := UpCase(CheckSection[i]);
           InSection := CheckSection = GetSectionName(VarName.S);
          END;
         SectionStart := TRUE;
        END;
      END;

    BEGIN
     Find_IN_INI_File := FALSE;
     Assign(IniFile, FileName);
     New(IniFileBuffer);
     SetTextBuf(IniFile,IniFileBuffer^);
     FileTimeOut      := 0;
     REPEAT
      {$I-}
       Reset(IniFile);
      {$I+}
      IniOpenErr := IOResult;
      IF IniOpenErr <> 0 THEN
       BEGIN
        Inc(FileTimeOut);
        FindFirst(FileName,anyFile,ASearchRec);
        IF (DosError <> 0) OR (FileTimeOut > MaxRetry) THEN BREAK; { IF FILE NOT THERE, FORGET IT }
        IF Assigned(PROP_CommsProc) THEN PROP_CommsProc;
       END;
     UNTIL IniOpenErr = 0;
     { if opened ini file OK check each line }
     IF IniOpenErr = 0 THEN
      BEGIN
       { Find Relevant Section In INI File }
       InSection := FALSE;
       WHILE NOT EOF(IniFile) DO
        BEGIN
         ReadLn(IniFile, WrkString);
         IF InSection THEN
          BEGIN
           { Next Section Found - Exit Cos Not Found Variable Name }
           IF SectionStart THEN Break;
           IF FoundInWrkString THEN   { Variable Found }
            BEGIN
             Find_IN_INI_FILE := TRUE;
             Break;
            END;
          END
         ELSE SectionStart  { Check For Section Start }
        END;
       Close(IniFile);
      END;
     Dispose(IniFileBuffer);
    END;

BEGIN
  GetExtVar := ''; INIFound := FALSE;
  { FOPS6INI_VAR has only one chance to be initialised by command line.
    See unit init.}
  IF (VarName.V = FXIniName.V) AND (FOPS6INI_VAR <> '') THEN
   BEGIN
    GetExtVar := FOPS6INI_VAR;
    INIfound  := TRUE;
    EXIT;
   END;

  { check command line }
  IF (SearchFrom AND cmdline) = cmdline THEN
   BEGIN
    FOR i := 1 TO ParamCount DO
     BEGIN
      WrkString := ParamStr(i);
      INIFound := FoundInWrkString;
      IF INIFound THEN EXIT;
     END;
   END;

  { check ini file }
  IF (SearchFrom AND ini) = ini THEN
   BEGIN
    WrkString := GetVarFromCache(VarName,IniFileCache);
    IF (NOT NowtButSpace(WrkString)) THEN
     BEGIN
      GetExtVar := WrkString;
      EXIT;
     END;
    INIFound := Find_IN_INI_File(FOPS6INI_VAR);
    IF INIFound THEN Exit;
   END;

  { check environmental variables }
  IF (SearchFrom AND env) = env THEN
   BEGIN
    WrkString := GetEnv(VarName.V);
    IF WrkString <> '' THEN
     BEGIN
      GetExtVar := WrkString;
      INIFound  := TRUE;
      Exit;
     END;
   END;

  { check fops6 system ini file }
  IF (SearchFrom AND sysini) = sysini THEN
   BEGIN
    WrkString := GetVarFromCache(VarName,SysIniFileCache);
    IF (NOT NowtButSpace(WrkString)) THEN
     BEGIN
      GetExtVar := WrkString;
      EXIT;
     END;
    INIFound := Find_IN_INI_File(SYSTEM_INI_NAME)
   END;
END;

PROCEDURE GetExtColours(VarName : INIVAR;SearchFrom : TExternSource;
                       VAR NB,LF,HF,RB,RF   : BYTE;
                        DNB,DLF,DHF,DRB,DRF : BYTE); {defaults}
VAR S : STRING;
    I : INTEGER;
    Dummy,Int : INTEGER;
    iPos : INTEGER;
BEGIN
 NB := DNB; LF := DLF; HF := DHF; RB := DRB; RF := DRF;
 S := GetExtVar(VarName,SearchFrom);
 IF NOT NowtButSpace(S) THEN
  BEGIN
   iPos := 0;
   REPEAT
    I := Pos(',',S);
    IF I = 0 THEN EXIT;
    IF I > 1 THEN
     BEGIN
      VAL(COPY(S,1,I-1),Int,Dummy);
      IF Dummy = 0 THEN
      CASE iPos OF
       0: NB := Int AND $07;
       1: LF := Int;
       2: HF := Int;
       3: RB := Int AND $07;
       4: RF := Int;
      END;
      INC(iPos);
     END;
    SYSTEM.Delete(S,1,I);
   UNTIL Length(S) = 0;
  END
END;



FUNCTION GetExtSwitch(VarName    : INIVAR;
		      SearchFrom : TExternSource;
		      Default    : BOOLEAN) : BOOLEAN;
VAR RetStr : STRING[3];
BEGIN
 { Call GetExtVar First To Find Variable }
 GetExtSwitch := Default;
 RetStr := GetExtVar(VarName,SearchFrom);
 RetStr := Stripped(RetStr,ORD(RetStr[0]),' ');
 IF (RetStr = '') THEN Exit;
 { Only Check First Caracter - This Means Y,y,yes,YES are Aceptable }
 IF (Upcase(RetStr[1]) = 'Y') THEN GetExtSwitch := TRUE
 ELSE GetExtSwitch := FALSE;
END;

