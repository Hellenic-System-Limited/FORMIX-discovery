FUNCTION GetExtFilePath  (VarName    : INIVAR;
		          SearchFrom : TExternSource;
                          Default    : STRING) : STRING;
{ If path is specified in 'INI', and it is available, then it will be
  returned ('\' terminated)  ELSE  default is returned as passed in. }
VAR Path       : STRING;
    ASearchRec : SearchRec;
    Root,
    HadASlash  : BOOLEAN;
    SearchDriveCurrDir,
    CurrentProgDir,
    CurrentDir : STRING;
    Drive      : BYTE;
BEGIN
 GetDir(0,CurrentProgDir);              { Save current directory }
 { Call GetExtVar First To Find Variable }
 Path := GetExtVar(VarName,SearchFrom);

 Path := Stripped(Path,Length(Path),' ');
 IF Path = '' THEN
  BEGIN
   Path := Default;
  { Now Check That Path Is Valid - This Check Requires No \ At End Of Path }
  { Unless it is the root directory }
  { Remove Any \ At End Of Path }
   HadASlash := (Path[Length(Path)] = '\');
  END
 ELSE HadASlash := TRUE; { path come from INI, force a slash onto end }

 { remove trailing slash if there's a directory name in 'Path' }
 IF (Path[Length(Path)] = '\') THEN Path[0] := CHAR(length(Path)-1);
 Root := (Path[Length(Path)] = ':');
 IF Root THEN Path := Path+'\';

 { Save current directory on that Search Drive }
 IF (Path[2] = ':') THEN
   Drive := ORD(Upcase(Path[1])) - ORD('A')+1
 ELSE  { no drive specified, search default drive }
   Drive := 0;
 GetDir(Drive,SearchDriveCurrDir);

 { botch to get around UNC paths ?}
 IF not ((Path[1] = '\') and (Path[2] = '\')) then
 BEGIN
   { Now try to change to that drive/directory }
   {$I-}
   ChDir(Path);
   {$I+}

   IF IOResult <> 0 THEN
    BEGIN
     Path := Default;     { SET PATH TO WHATEVER IS IN 'Default' }
     { re-strip slash off because one gets appended later }
     IF (Path[Length(Path)] = '\') THEN
      BEGIN
       HadASlash := TRUE;
       Path[0] := CHAR(length(Path)-1);
      END;
    END;
 END;

 { where am i - could be on right drive but wrong dir }
 GetDir(0, CurrentDir);
 { if switched drive, restore current dir on that drive }
 IF (Copy(CurrentDir,1,2) <> Copy(CurrentProgDir,1,2)) THEN
  BEGIN
   { Re-establish current directory on that drive }
   {$I-}
   ChDir(SearchDriveCurrDir);
   {$I+}
   IF IOResult <> 0 THEN
     Disp_Error_Msg('Error Changing Directory back to '+SearchDriveCurrDir);
  END;

 { Return to initial drive/directory }
 {$I-}
 ChDir(CurrentProgDir);
 {$I+}
 IF IOResult <> 0 THEN
   Disp_Error_Msg('Error Changing Directory back to '+CurrentProgDir);

 { Replace '\' to end of path if not root }
 IF (NOT Root) AND HadASlash THEN
   Path := Path + '\';

 GetExtFilePath := Path;
END;

FUNCTION GetExtPath  (VarName    : INIVAR;
		      SearchFrom : TExternSource) : STRING;
BEGIN
 GetExtPath := GetExtFilePath(VarName,SearchFrom,(*TRUE,*)'.\');
END;

FUNCTION GetUpCaseExtVar(VarName    : INIVAR;
			 SearchFrom : TExternSource) : STRING;
VAR RetStr : STRING;
    i      : BYTE;
BEGIN
 { Find External Variable }
 RetStr := GetExtVar(VarName,SearchFrom);
 { Make All Lower Case Letters Upper Caes }
 FOR i := 1 TO ORD(RetStr[0]) DO RetStr[i] := Upcase(RetStr[i]);
 { Return String}
 GetUpCaseExtVar := RetStr;
END;

FUNCTION GetExtNum      (VarName    : INIVAR;
			 SearchFrom : TExternSource;
			 Min,Max,
			 Default    : LONGINT) : LONGINT;
VAR Value : LONGINT;
    RetStr: STRING[9]; { Will Always VAL Into LONGINT With Out 201 }
    ErrInt: INTEGER;
BEGIN
 RetStr := GetExtVar(VarName,SearchFrom);
 IF RetStr <> '' THEN
  BEGIN
   VAL(RetStr,Value,ErrInt);
   IF (ErrInt<>0) OR (Value < Min) OR (Value > Max) THEN Value := Default;
  END
 ELSE Value := Default;
 GetExtNum := Value;
END;

FUNCTION GetExtFloat    (VarName    : INIVAR;
			 SearchFrom : TExternSource;
			 Min,Max,
			 Default    : DOUBLE) : DOUBLE;
VAR Value : DOUBLE;
    RetStr: STRING[30]; { Should VAL Into Double With Out Error 201 }
    ErrInt: INTEGER;
BEGIN
 RetStr := GetExtVar(VarName,SearchFrom);
 IF RetStr <> '' THEN
  BEGIN
   VAL(RetStr,Value,ErrInt);
   IF (ErrInt <> 0) OR (Value < Min) OR (Value > Max) THEN Value := Default;
  END
 ELSE Value := Default;
 GetExtFloat := Value;
END;


BEGIN
 IniFileCache := NIL;
 SysIniFileCache := NIL;
  FOPS6INI_VAR := '';
  FOPS6INI_VAR := GetExtVar(FXININame,cmdLine);
  IF FOPS6INI_VAR = '' THEN FOPS6INI_VAR := SYSTEM_INI_NAME
  ELSE
